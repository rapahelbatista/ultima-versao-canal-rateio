# EquipeChat Monitor API — Environment Variables
# Copy to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=monitor_db
DB_USER=monitor_user
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_RANDOM_SECRET

# API Port
PORT=3200

# Email notifications (optional — Resend.com)
RESEND_API_KEY=
ADMIN_EMAIL=admin@equipechat.com
