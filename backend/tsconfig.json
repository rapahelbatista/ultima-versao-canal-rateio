{
  "compilerOptions": {
    "target": "es2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "strict": false,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@whiskeysockets/baileys": ["src/compat/baileys"],
      "@whiskeysockets/baileys/*": ["node_modules/@itsukichan/baileys/*"]
    }
  },
  "exclude": ["public"]
}
